#: libs/theme-setup.php:1292
msgid "Recurring Payment on %website_url"
msgstr "Періодичний платіж на %website_url"

#: libs/theme-setup.php:1295
msgid ""
"Hi there,\n"
"We charged your account on %merchant for a subscription on %website_url ! "
